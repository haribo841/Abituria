<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Abituria.App"
             RequestedThemeVariant="Light">
  <Application.Styles>
    <FluentTheme />

    <Style Selector="TextBlock.h1">
      <Setter Property="FontSize" Value="36" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Foreground" Value="#17202A" />
    </Style>

    <Style Selector="TextBlock.h2">
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#17202A" />
    </Style>

    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#637083" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#256D85" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="#EDF2F4" />
      <Setter Property="Foreground" Value="#17202A" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="10,8" />
    </Style>
  </Application.Styles>
</Application>
